@page "/reset-password"
@using Newtonsoft.Json;
@using System.ComponentModel.DataAnnotations
@using GC = FrontendLogin.GlobalConstants;
@using Common.DTO.Base;
@inject HttpClient Http
@inject NavigationManager Nav
@inject HttpClient HttpClient
@inject IHttpClientFactory HttpClientFactory
@inject IHttpContextAccessor HttpContextAccessor
@inject LabelService LS


<div class="d-flex justify-content-center align-items-center vh-100 bg-light">
    <div class="card shadow-lg p-4" style="width: 400px; border-radius: 12px;">
        
        <h3 class="text-center mb-4">🔐 @GetLabel("ChgPw")</h3>

        <EditForm Model="_model" OnValidSubmit="HandleResetPassword">
            <DataAnnotationsValidator />
            
            <div class="mb-3">
                <label class="form-label">@GetLabel("PWn")</label>
                <InputText class="form-control" @bind-Value="_model.Password" type="@passwordInputType" />
            </div>

            <div class="mb-3">
                <label class="form-label">@GetLabel("PWc")</label>
                <InputText class="form-control" @bind-Value="_model.ConfirmPassword" type="@passwordInputType" />
            </div>

            <div class="form-check mb-2">
                <InputCheckbox class="form-check-input" @bind-Value="_showPassword" id="showPassword" />
                <label class="form-check-label" for="rememberMe">@GetLabel("PWsw")</label>
            </div>

            <div class="mt-3 mb-3">
                <label class="form-label"></label>
                <button type="submit" class="btn btn-primary w-100">
                    @GetLabel("ChgPw")
                </button>
            </div>

        </EditForm>

        <div class="form-check mb-2">
            <button type="button" class="btn btn-link p-0" @onclick="ShowRules">
                @GetLabel("PWsr")
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            @_message
        }

        <p>@((MarkupString)rules)</p>
        <p>@successMessage</p>
        <p>@errorMessage</p>

    </div>
</div>


@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public int? OrgNr { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? LangCode { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public int? LangVariant { get; set; }


    private Dictionary<string, LangLabelDto> labels = new Dictionary<string, LangLabelDto>();
    private ResetPasswordModel _model = new();
    private bool _showPassword = false;
    private bool _showRules = false;
    private string _message = string.Empty;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private string rules = string.Empty;


    private string passwordInputType => _showPassword ? "text" : "password";

    private async Task HandleResetPassword()
    {
        if (_model.Password != _model.ConfirmPassword)
        {
            _message = GetLabel("PWx");
            return;
        }

        var action = new LoginResetActionDto
        {
            Token = Token,
            Password = _model.Password
        };

        var client = HttpClientFactory.CreateClient(GC.HTTP_Client);
        var response = await client.PostAsJsonAsync(GC.URL_reset_action, action);
        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadAsStringAsync();
            var dto = JsonConvert.DeserializeObject<_ResponseDto>(result);

            if (!dto.Valid)
            {
                errorMessage = dto.ErrorMessage;
                return;
            }
            successMessage = dto.SuccessMessage;
            return;
        }
        errorMessage = GetLabel("Oops");
    }

    private string GetLabel(string key)
    {
        return LS.GetLabel(key, labels);
    }

    private async void ShowRules()
    {
        _showRules = !_showRules;
        rules = string.Empty;

        if (_showRules)
        {
            var url = GC.URL_show_password_rules
                                    + "?orgNr=" + OrgNr
                                    + "&langcode=" + LangCode;

            var client = HttpClientFactory.CreateClient(GC.HTTP_Client);
            var response = await client.GetAsync(url);
            var r = await response.Content.ReadAsStringAsync();
            var dto = JsonConvert.DeserializeObject<_ResponseDto>(r);

            rules = dto.Result.ToString();
        }
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        if (LangCode == null)
            LangCode = GC.LangCodeDefault;


        labels = await LS.InitialiseLabels(LangCode, LangVariant);
    }


    public class ResetPasswordModel
    {
        public string Password { get; set; }
        public string ConfirmPassword { get; set; }
    }
}