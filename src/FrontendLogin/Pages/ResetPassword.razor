@page "/reset-password/{Token}"
@using Newtonsoft.Json;
@using System.ComponentModel.DataAnnotations
@using MudBlazor
@using GC = FrontendLogin.GlobalConstants;
@using Common.DTO.Base;
@inject HttpClient Http
@inject NavigationManager Nav
@inject HttpClient HttpClient
@inject IHttpClientFactory HttpClientFactory
@inject IHttpContextAccessor HttpContextAccessor


<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="height:100vh;">
    <MudPaper Elevation="6" Class="pa-6 rounded-lg" Style="width:420px;">

        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-4">
            Reset Your Password
        </MudText>

        <EditForm Model="_model" OnValidSubmit="HandleResetPassword">
            <DataAnnotationsValidator />
            
            <MudTextField T="string"
                          Label="New Password"
                          @bind-Value="_model.Password"
                          For="@(() => _model.Password)"
                          InputType="@passwordInputType"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="mb-3" />

            <MudTextField T="string"
                          Label="Confirm Password"
                          @bind-Value="_model.ConfirmPassword"
                          For="@(() => _model.ConfirmPassword)"
                          InputType="@passwordInputType"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="mb-3" />

            <MudCheckBox @bind-value="_showPassword" Color="Color.Primary" Class="mb-4">
                Show Passwords
            </MudCheckBox>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       ButtonType="ButtonType.Submit">
                Reset Password
            </MudButton>

        </EditForm>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">
                @_message
            </MudAlert>
        }


        <p>@successMessage</p>
        <p>@errorMessage</p>

    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public string Token { get; set; }

    private ResetPasswordModel _model = new();
    private bool _showPassword;
    private string _message;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private InputType passwordInputType =>
        _showPassword ? InputType.Text : InputType.Password;

    private async Task HandleResetPassword()
    {
        if (_model.Password != _model.ConfirmPassword)
        {
            _message = "Passwords do not match.";
            return;
        }
        
        var payload = new
        {
            Token = Token,
            Password = _model.Password
        };

        var client = HttpClientFactory.CreateClient(GC.HTTP_Client);
        var response = await client.PostAsync(GC.URL_reset_request, payload);
        var r = await response.Content.ReadAsStringAsync();
        var dto = JsonConvert.DeserializeObject<_ResponseDto>(r);

        
        if (!dto.Valid)
        {
            errorMessage = dto.ErrorMessage;
            return;
        }

        var login = JsonConvert.DeserializeObject<LoginSuccessDto>(dto.Result.ToString());
        successMessage = dto.SuccessMessage;

    }

    public class ResetPasswordModel
    {
        [Required(ErrorMessage = "Password is required")]
        [MinLength(6, ErrorMessage = "Minimum 6 characters")]
        public string Password { get; set; }

        [Required(ErrorMessage = "Confirm your password")]
        public string ConfirmPassword { get; set; }
    }
}