{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Serilog": {

    "Using": [
      "Serilog.Sinks.File",
      "Serilog.Sinks.Seq",
      "Serilog.Formatting.Compact",
      "Serilog.Filters.Expressions"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Error",
        "Microsoft.AspNetCore.Mvc": "Error",
        "Microsoft.AspNetCore": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter,Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },

  "PathBase": "/v123",

  "ConnectionStrings": {
    "DBMainConnection_sqlserver": "Server=np:localhost;Database=blue;TrustServerCertificate=True;Authentication=Active Directory Integrated;",
    "DBMainConnection": ""
  },

  "Token": {
    "CacheExpirationAddSeconds": 150,
    "CacheExpirationGetSeconds": 30,
    "MaxGetTokenCalls": 1,
    "AccessTokenMinutes": 2,
    "RefreshTokenDays": 7
  },

  "Mfa": {
    "AuthenticatorAppName": "Blue"
  },

  "Cors": {
    "AllowedOrigins": "https://localhost:7289"
  },

  "Urls": {
    "comment": "Duplicated in launchSettings.json to allow Visual Studio to run",
    "Api": "https://localhost:6002/v123/",
    "Client": "https://localhost:7171/",
    "Login": "https://localhost:7289/"
  },

  "ServiceAccount": {
    "Username": "$",
    "PW": "$",
    "Email": "js@7orcas.com",
    "AttemptsFile": "c:\\temp\\_serviceAttempts.txt"
  },

  "EmailSettings": {
    "comment": "Settings are stored in the secrets.json file"
  }

}