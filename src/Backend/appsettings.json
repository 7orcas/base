{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Serilog": {

    "Using": [
      "Serilog.Sinks.File",
      "Serilog.Sinks.Seq",
      "Serilog.Formatting.Compact",
      "Serilog.Filters.Expressions"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Error",
        "Microsoft.AspNetCore.Mvc": "Error",
        "Microsoft.AspNetCore": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter,Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },

  "PathBase": "/v123",

  "ConnectionStrings": {
    "DBMainConnection_sqlserver": "Server=np:localhost;Database=blue;TrustServerCertificate=True;Authentication=Active Directory Integrated;",
    "DBMainConnection": "Host=localhost;Port=5432;Database=blue;Username=postgres;Password=js;"
  },

  "Token": {
    "CacheExpirationAddSeconds": 150,
    "CacheExpirationGetSeconds": 100,
    "MaxGetTokenCalls": 2
  },

  "Urls": {
    "MainClientUrl": "https://localhost:7171"
  },

  "ServiceAccount": {
    "UserId": "$",
    "PW": "$",
    "AttemptsFile": "c:\\temp\\_serviceAttempts.txt"
  }
}