{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Formatting.Compact" ],
    "MinimumLevel": {
      "Default": "Verbose", //Verbose,Debug,Information,Warning,Error,Fatal
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter,Serilog.Formatting.Compact" //json format of log, remove if you prefer plain text
        }
      }
    ]
  },

  "PathBase": "/v123",

  "ConnectionStrings": {
    "DBMainConnection_sqlserver": "Server=np:localhost;Database=blue;TrustServerCertificate=True;Authentication=Active Directory Integrated;",
    "DBMainConnection": "Host=localhost;Port=5432;Database=blue;Username=postgres;Password=js;"
  },

  "Token": {
    "CacheExpirationAddSeconds": 150,
    "CacheExpirationGetSeconds": 100,
    "MaxGetTokenCalls": 2
  },

  "Urls": {
    "MainClientUrl": "https://localhost:7171"
  },

  "ServiceAccount": {
    "UserId": "$",
    "PW": "$",
    "AttemptsFile": "c:\\temp\\_serviceAttempts.txt"
  }
}